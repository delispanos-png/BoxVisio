PROJECT_NAME=CloudOn BI
ENVIRONMENT=dev
COMPOSE_PROJECT_NAME=cloudon_bi
SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_SECRET
BI_SECRET_KEY=CHANGE_ME_BI_SECRET_KEY_BASE64_32_BYTES
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=30
DEFAULT_TRIAL_DAYS=14
PAST_DUE_GRACE_DAYS=7
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

API_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
POSTGRES_PORT=5432
REDIS_PORT=6379

CONTROL_DB_USER=bi_control
CONTROL_DB_PASSWORD=CHANGE_ME_CONTROL_DB_PASSWORD
CONTROL_DB_NAME=bi_control
CONTROL_DB_HOST=postgres
CONTROL_DB_PORT=5432
CONTROL_DATABASE_URL=postgresql+asyncpg://bi_control:CHANGE_ME_CONTROL_DB_PASSWORD@postgres:5432/bi_control
CONTROL_DATABASE_URL_SYNC=postgresql+psycopg://bi_control:CHANGE_ME_CONTROL_DB_PASSWORD@postgres:5432/bi_control

TENANT_DB_HOST=postgres
TENANT_DB_PORT=5432
TENANT_DB_SUPERUSER=postgres
TENANT_DB_SUPERPASS=CHANGE_ME_POSTGRES_SUPERPASS
TENANT_DB_PREFIX=bi_tenant_
TENANT_DATABASE_URL_TEMPLATE=postgresql+asyncpg://{user}:{password}@postgres:5432/{db_name}
TENANT_DATABASE_URL_TEMPLATE_SYNC=postgresql+psycopg://{user}:{password}@postgres:5432/{db_name}
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
TENANT_ENGINE_CACHE_SIZE=64

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
INGEST_JOB_MAX_RETRIES=3
INGEST_RETRY_BACKOFF_SECONDS=5
INGEST_DRAIN_MAX_JOBS=100
RATE_LIMIT_PER_MINUTE=120
INGEST_TENANT_LOCK_TTL_SECONDS=300
INGEST_THROTTLE_JOBS_PER_WINDOW=120
INGEST_THROTTLE_WINDOW_SECONDS=60
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

WHMCS_WEBHOOK_SECRET=
DEFAULT_ADMIN_EMAIL=admin@boxvisio.com
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

ODBC_DRIVER=ODBC Driver 18 for SQL Server
TENANT_PORTAL_HOST=bi.boxvisio.com
ADMIN_PORTAL_HOST=adminpanel.boxvisio.com
SERVER_PUBLIC_IP=
SQLSERVER_DEFAULT_PORT=1433

BACKUP_ROOT=/opt/cloudon-bi/backups
BACKUP_RETENTION_DAYS=14
BACKUP_METRICS_FILE=/opt/cloudon-bi/infra/monitoring/node-exporter-textfiles/cloudon_backup.prom
