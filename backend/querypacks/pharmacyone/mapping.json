{
  "name": "pharmacyone_default",
  "version": 2,
  "required_parameters": ["@from_date", "@to_date", "@last_sync_ts", "@last_sync_id"],
  "incremental_strategy": {
    "mode": "updated_at_then_external_id",
    "updated_at_column": "updated_at",
    "id_column": "external_id",
    "date_column": "doc_date"
  },
  "required_output_columns": {
    "doc_date": "Document date (date)",
    "branch_external_id": "Branch identifier from source",
    "item_external_id": "Item identifier from source",
    "warehouse_external_id": "Warehouse identifier from source (nullable)",
    "supplier_external_id": "Supplier identifier for purchases",
    "qty": "Quantity",
    "net_amount": "Net amount",
    "cost_amount": "Cost amount",
    "external_id": "Stable source line identifier",
    "updated_at": "Source update timestamp",
    "qty_on_hand": "Inventory quantity on hand (inventory stream)",
    "qty_reserved": "Inventory quantity reserved (inventory stream)",
    "value_amount": "Inventory stock value (inventory stream)",
    "entry_type": "Cashflow entry type or business subcategory (cashflow stream)",
    "amount": "Cashflow amount (cashflow stream)",
    "currency": "Cashflow currency (cashflow stream)",
    "reference_no": "Cashflow source reference number (cashflow stream)",
    "supplier_id": "Supplier identifier (supplier balances stream)",
    "balance_date": "Snapshot date for supplier balance stream",
    "open_balance": "Open supplier balance amount",
    "overdue_balance": "Overdue supplier balance amount",
    "aging_bucket_0_30": "Aging bucket 0-30 days",
    "aging_bucket_31_60": "Aging bucket 31-60 days",
    "aging_bucket_61_90": "Aging bucket 61-90 days",
    "aging_bucket_90_plus": "Aging bucket 90+ days",
    "last_payment_date": "Last supplier payment date",
    "trend_vs_previous": "Delta vs previous snapshot",
    "customer_id": "Customer identifier (customer balances stream)",
    "last_collection_date": "Last collection date for customer receivables",
    "expense_date": "Expense date for operating expense stream",
    "amount_net": "Operating expense net amount",
    "amount_tax": "Operating expense VAT amount",
    "amount_gross": "Operating expense gross amount"
  },
  "column_mappings": {
    "branch_column": "branch_external_id",
    "item_column": "item_external_id",
    "qty_column": "qty",
    "amount_column": "net_amount",
    "cost_column": "cost_amount",
    "incremental_column": "updated_at",
    "id_column": "external_id",
    "date_column": "doc_date"
  },
  "dimension_mappings": {
    "dim_branches.external_id": "branch_external_id",
    "dim_items.external_id": "item_external_id",
    "dim_suppliers.external_id": "supplier_external_id",
    "dim_warehouses.external_id": "warehouse_external_id",
    "dim_brands.external_id": "brand_external_id",
    "dim_categories.external_id": "category_external_id",
    "dim_groups.external_id": "group_external_id"
  }
}
